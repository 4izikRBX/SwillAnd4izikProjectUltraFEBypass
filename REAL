local function scanAllRemotes()
    print("[4izik] Сканирование ремоутов...")
    _G.SWILL.AllRemotes = {}

    local function deepScan(parent, path)
        if not parent or not pcall(function() return parent.GetChildren end) then return end
        local success, children = pcall(function() return parent:GetChildren() end)
        if not success then return end

        for _, child in pairs(children) do
            local fullPath = path and (path .. "." .. child.Name) or child.Name
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(_G.SWILL.AllRemotes, {
                    Name = child.Name,
                    Path = fullPath,
                    Type = child.ClassName,
                    FullPath = child:GetFullName(),
                    Remote = child
                })
            end
            deepScan(child, fullPath)
        end
    end

    local allContainers = {game, Workspace, ReplicatedStorage, ReplicatedFirst, ServerStorage, 
        ServerScriptService, Lighting, Players, CoreGui, StarterGui, StarterPack, StarterPlayer,
        LocalPlayer, LocalPlayer:FindFirstChild("PlayerGui")}

    for _, container in pairs(allContainers) do
        if container then pcall(function() deepScan(container, container.Name) end) end
    end

    print(string.format("[4izik] Найдено ремоутов: %d", #_G.SWILL.AllRemotes))
    return _G.SWILL.AllRemotes
end

